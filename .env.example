OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# openai | disabled
LLM_MODE=openai

# Folder cu PDF-uri (manuale/scheme/forum PDFs)
MANUALS_DIR=./data/manuals

# Note markdown versionate în repo (folder knowledge/public), folosite la ingest script
PUBLIC_NOTES_DIR=./knowledge/public

# Persistență index RAG
VECTORSTORE_DIR=./data/vectorstore

# Folder cu loguri VCDS (Windows example: C:\\Ross-Tech\\VCDS\\Logs)
VCDS_LOG_DIR=

# Folder pentru loguri încărcate manual (când nu ai VCDS instalat încă)
UPLOADED_LOGS_DIR=./data/uploaded-logs

# Copii locale ale fișierelor încărcate prin POST /ingest-files (PDF/MD/TXT)
INGEST_UPLOADS_DIR=./data/ingested-uploads

# Limitări simple
MAX_CONTEXT_CHUNKS=6

